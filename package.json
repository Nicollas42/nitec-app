{
  "name": "nitec_app",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "main": "app_desktop.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "electron:start": "electron app_desktop.cjs",
    "electron:build": "vite build && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-updater": "^6.1.8", 
    "pinia": "^3.0.4",
    "sweetalert2": "^11.10.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "electron": "^40.6.1",
    "electron-builder": "^24.13.3",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  },
  "build": {
    "appId": "br.dev.nitec.pdv",
    "productName": "NitecSystem",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "app_desktop.cjs"
    ],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Nitec PDV"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Nicollas42",
        "repo": "nitec-atualizacoes" 
      }
    ]
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}