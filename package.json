{
  "name": "nitec_app",
  "version": "1.1.59",
  "private": true,
  "type": "module",
  "main": "app_desktop.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "electron:start": "electron app_desktop.cjs",
    "electron:build": "vite build && electron-builder --win",
    "android:build": "npx cap sync android && cd android && gradlew assembleRelease",
    "release": "node release.cjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "bonjour-service": "^1.3.0",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "dexie": "^4.3.0",
    "electron-updater": "^6.1.8",
    "express": "^5.2.1",
    "fflate": "^0.8.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qrcode.vue": "^3.8.0",
    "sweetalert2": "^11.10.0",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "^3.5.29",
    "vue-chartjs": "^5.3.3",
    "vue-qrcode-reader": "^5.7.3",
    "vue-router": "^5.0.3",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  },
  "build": {
    "appId": "br.dev.nitec.pdv",
    "productName": "NitecSystem",
    "asar": false,
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "app_desktop.cjs",
      "servidor_local.cjs",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/@capacitor/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/vite/**/*",
      "!node_modules/typescript/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Nitec PDV"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Nicollas42",
        "repo": "nitec-atualizacoes"
      }
    ]
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
